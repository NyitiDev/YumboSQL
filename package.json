{
  "name": "yumbosql",
  "version": "0.1.0",
  "description": "PostgreSQL Admin Tool for macOS",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:renderer": "cd src/renderer && npx vite --port 3000",
    "build:renderer": "cd src/renderer && npx vite build",
    "build": "npm run build:renderer && electron-builder",
    "lint": "eslint src/"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "pg": "^8.13.0",
    "keytar": "^7.9.0"
  },
  "build": {
    "appId": "com.yumbosql.app",
    "productName": "YumboSQL",
    "directories": {
      "output": "release"
    },
    "npmRebuild": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "title": "YumboSQL",
      "sign": false
    },
    "files": [
      "src/main/**/*",
      "src/renderer/dist/**/*",
      "logo_transparent.png",
      "build/icon.icns",
      "package.json"
    ],
    "extraMetadata": {
      "main": "src/main/main.js"
    }
  }
}
